{
  "name": "bingwu-create",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "description": "快速拉取项目模版的 CLI 工具",
  "author": "hujiacheng",
  "license": "MIT",
  "homepage": "https://github.com/BINGWU2003/bingwu-create#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BINGWU2003/bingwu-create.git"
  },
  "bugs": "https://github.com/BINGWU2003/bingwu-create/issues",
  "keywords": [
    "create",
    "template",
    "scaffold",
    "cli"
  ],
  "bin": {
    "bingwu-create": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@clack/prompts": "catalog:deps",
    "kolorist": "catalog:deps"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "lint-staged": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
